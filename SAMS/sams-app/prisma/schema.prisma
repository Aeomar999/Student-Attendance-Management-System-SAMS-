generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  LECTURER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model Institution {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  address   String?
  phone     String?
  email     String?
  status    String   @default("ACTIVE")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users     User[]
  students  Student[]
  courses   Course[]
  rooms     Room[]
  departments Department[]

  @@index([code])
  @@index([status])
  @@map("institutions")
}

model Department {
  id           String   @id @default(cuid())
  name         String
  code         String   @unique
  description  String?

  institutionId String @map("institution_id")
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users    User[]
  students Student[]
  courses  Course[]

  @@index([institutionId])
  @@index([code])
  @@map("departments")
}

model FaceEnrollment {
  id            String   @id @default(cuid())
  studentId     String   @unique @map("student_id")
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  embeddings    Bytes?   @db.ByteA
  imageCount    Int      @default(0) @map("image_count")
  qualityScore  Float?   @map("quality_score")
  enrolledAt    DateTime @default(now()) @map("enrolled_at")
  enrolledBy    String?  @map("enrolled_by")
  status        String   @default("ACTIVE")

  @@index([studentId])
  @@map("face_enrollments")
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String?    @map("password_hash")
  firstName    String     @map("first_name")
  lastName     String     @map("last_name")
  role         UserRole   @default(LECTURER)
  status       UserStatus @default(ACTIVE)

  mfaEnabled     Boolean   @default(false) @map("mfa_enabled")
  failedAttempts Int       @default(0) @map("failed_attempts")
  lockedUntil    DateTime? @map("locked_until")
  lastLoginAt    DateTime? @map("last_login_at")

  institutionId String? @map("institution_id")
  institution   Institution? @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  departmentId  String? @map("department_id")
  department    Department? @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sessions Session[]
  accounts Account[]

  @@index([email])
  @@index([status])
  @@index([role])
  @@index([institutionId])
  @@index([departmentId])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model SetupToken {
  id        String   @id @default(cuid())
  token     String   @unique
  email     String
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([token])
  @@index([email])
  @@map("setup_tokens")
}

model Student {
  id           String     @id @default(cuid())
  studentId    String     @unique @map("student_id")
  firstName    String     @map("first_name")
  lastName     String     @map("last_name")
  email        String     @unique
  yearOfStudy  Int        @map("year_of_study")
  program      String
  status       UserStatus @default(ACTIVE)
  faceEnrolled Boolean    @default(false) @map("face_enrolled")

  institutionId String @map("institution_id")
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  departmentId  String @map("department_id")
  department    Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  courses StudentCourse[]
  faceEnrollment FaceEnrollment?

  @@index([studentId])
  @@index([email])
  @@index([status])
  @@index([program])
  @@index([faceEnrolled])
  @@index([institutionId])
  @@index([departmentId])
  @@map("students")
}

model Course {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  semester    String?
  capacity    Int      @default(0)
  status      String   @default("ACTIVE")

  departmentId  String @map("department_id")
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  lecturerId    String @map("lecturer_id")
  institutionId String @map("institution_id")
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sessions  AttendanceSession[]
  schedules Schedule[]
  students  StudentCourse[]

  @@index([code])
  @@index([departmentId])
  @@index([lecturerId])
  @@index([status])
  @@index([institutionId])
  @@map("courses")
}

model StudentCourse {
  id        String   @id @default(cuid())
  studentId String   @map("student_id")
  courseId  String   @map("course_id")
  enrolledAt DateTime @default(now()) @map("enrolled_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course  Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId])
  @@index([studentId])
  @@index([courseId])
  @@map("student_courses")
}

model AttendanceSession {
  id          String    @id @default(cuid())
  courseId    String    @map("course_id")
  lecturerId  String    @map("lecturer_id")
  sessionDate DateTime  @map("session_date") @db.Date
  startTime   DateTime  @map("start_time")
  endTime     DateTime? @map("end_time")
  status      String    @default("SCHEDULED")
  gracePeriod Int       @default(15) @map("grace_period")

  totalPresent Int @default(0) @map("total_present")
  totalAbsent  Int @default(0) @map("total_absent")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  course Course? @relation(fields: [courseId], references: [id], onDelete: Cascade)

  records AttendanceRecord[]

  @@index([courseId])
  @@index([lecturerId])
  @@index([sessionDate])
  @@index([status])
  @@index([courseId, sessionDate])
  @@map("attendance_sessions")
}

model AttendanceRecord {
  id              String    @id @default(cuid())
  sessionId       String    @map("session_id")
  studentId       String    @map("student_id")
  status          String    @default("ABSENT")
  recognizedAt    DateTime? @map("recognized_at")
  confidenceScore Float?    @map("confidence_score")
  isManual        Boolean   @default(false) @map("is_manual")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  session AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, studentId])
  @@index([sessionId])
  @@index([studentId])
  @@index([status])
  @@index([sessionId, status])
  @@map("attendance_records")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?  @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  oldValues  String?  @map("old_values")
  newValues  String?  @map("new_values")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([entityType])
  @@index([createdAt])
  @@index([action])
  @@map("audit_logs")
}

model MfaCredential {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  type      String   @default("totp") // totp, sms, email
  secret    String
  backupCodes String[] @default([]) @map("backup_codes")
  phone     String?  @map("phone")
  verified  Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, type])
  @@index([userId])
  @@map("mfa_credentials")
}

model PasswordHistory {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([createdAt])
  @@map("password_history")
}

model Room {
  id          String   @id @default(cuid())
  name        String
  building    String?
  capacity    Int      @default(0)
  description String?
  status      String   @default("ACTIVE")

  institutionId String @map("institution_id")
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  schedules Schedule[]

  @@index([name])
  @@index([institutionId])
  @@index([status])
  @@map("rooms")
}

model Schedule {
  id          String   @id @default(cuid())
  courseId    String   @map("course_id")
  dayOfWeek   String   @map("day_of_week")
  startTime   String   @map("start_time")
  endTime     String   @map("end_time")
  roomId      String?  @map("room_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  course Course?  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  room   Room?    @relation(fields: [roomId], references: [id])

  @@index([courseId])
  @@index([roomId])
  @@index([dayOfWeek])
  @@map("schedules")
}
